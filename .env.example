# Copy this file to .env and fill in the real values.

DB_URL=jdbc:postgresql://localhost:5432/pawnscan
DB_USERNAME=postgres
DB_PASSWORD=your_dev_db_password
POSTGRES_DB=pawnscan
JWT_SECRET=generate_a_secure_random_secret_at_least_32_chars

# Google OAuth.
# Use the Web application OAuth client ID for the backend and web app.
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# Backend runtime.
UPLOAD_BASE_DIR=uploads
BIKE_INDEX_API_BASE_URL=https://bikeindex.org/api/v3

# Optional Firebase Admin SDK service-account JSON.
# Leave empty if Firebase Admin is not needed locally.
# Example format: FIREBASE_CREDENTIALS='{"type":"service_account",...}'
FIREBASE_CREDENTIALS=

# SMTP email delivery.
# SendGrid: keep SMTP_HOST=smtp.sendgrid.net, SMTP_USERNAME=apikey,
# then set SMTP_PASSWORD or SENDGRID_API_KEY to your SendGrid API key.
# Gmail: use SMTP_HOST=smtp.gmail.com, SMTP_USERNAME=your Gmail address,
# SMTP_PASSWORD=your Google app password, and APP_MAIL_FROM=that same Gmail address.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
SENDGRID_API_KEY=
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_STARTTLS_REQUIRED=false
SMTP_SSL_TRUST=smtp.sendgrid.net
SMTP_CONNECTION_TIMEOUT=5000
SMTP_TIMEOUT=5000
SMTP_WRITE_TIMEOUT=5000
APP_MAIL_FROM=pawnscan1@gmail.com

# Web app.
# BACKEND_URL is used by Next.js server routes.
# NEXT_PUBLIC_BACKEND_URL is exposed to browser code.
BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
