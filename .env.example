# Copy this file to .env and fill in the real values.

DB_URL=jdbc:postgresql://localhost:5432/pawnscan
DB_USERNAME=postgres
DB_PASSWORD=your_dev_db_password
POSTGRES_DB=pawnscan
JWT_SECRET=generate_a_secure_random_secret_at_least_32_chars
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# Optional for direct Next.js local runs from ./web.
# Docker and the new /api/auth/google/config fallback can use GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
