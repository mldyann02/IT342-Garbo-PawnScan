<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme using AppCompat for XML-based layouts -->
    <style name="Theme.PawnScan" parent="Theme.AppCompat.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryDark">@color/bg_main_dark</item>
        <item name="colorAccent">@color/brand_green</item>
        
        <!-- Background -->
        <item name="android:windowBackground">@color/bg_main_dark</item>
        
        <!-- Text appearance -->
        <item name="android:textColorPrimary">@color/text_white</item>
        <item name="android:textColorSecondary">@color/text_muted_gray</item>
        
        <!-- Window styling -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/bg_main_dark</item>
        <item name="android:navigationBarColor">@color/bg_main_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Button styling -->
        <item name="buttonStyle">@style/Widget.AppCompat.Button.Colored</item>
    </style>

    <!-- Extra bold headline style -->
    <style name="HeadlineExtraBold">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">@color/text_white</item>
    </style>
</resources>