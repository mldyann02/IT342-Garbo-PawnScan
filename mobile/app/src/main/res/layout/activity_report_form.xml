<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <ScrollView
        android:id="@+id/portal_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/portal_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/report_form_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/portal_create_title"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Add details that help partner businesses identify your item quickly."
                android:textColor="@color/text_muted_gray"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/report_form_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_mobile_feature_card"
                android:padding="12dp"
                android:textSize="12sp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/report_form_serial"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/input_field_background"
                android:hint="@string/portal_serial_hint"
                android:inputType="text"
                android:maxLength="255"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_placeholder"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/report_form_model"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_field_background"
                android:hint="@string/portal_model_hint"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_placeholder"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/report_form_description"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_field_background"
                android:gravity="top"
                android:hint="@string/portal_description_hint"
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_placeholder"
                android:textSize="14sp" />

            <Button
                android:id="@+id/report_form_choose_files"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/button_rounded_pill_outline_green"
                android:stateListAnimator="@null"
                android:text="@string/portal_choose_files"
                android:textAllCaps="false"
                android:textColor="@color/brand_green"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/report_form_selected_files"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_muted_gray"
                android:textSize="12sp" />

            <Button
                android:id="@+id/report_form_submit"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/button_rounded_pill_green"
                android:stateListAnimator="@null"
                android:text="@string/portal_submit_report"
                android:textAllCaps="false"
                android:textColor="@color/bg_main_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/report_form_cancel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_field_background"
                android:stateListAnimator="@null"
                android:text="@string/portal_cancel_edit"
                android:textAllCaps="false"
                android:textColor="@color/text_light_gray"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/portal_nav"
        layout="@layout/include_portal_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
