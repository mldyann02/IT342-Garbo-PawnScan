<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <ScrollView
        android:id="@+id/portal_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/portal_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/portal_profile_title"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Keep your contact information current for recovery updates."
                android:textColor="@color/text_muted_gray"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/profile_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_mobile_feature_card"
                android:padding="12dp"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/profile_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_mobile_feature_card"
                android:padding="16dp"
                android:textColor="@color/text_light_gray"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/profile_full_name"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/input_field_background"
                android:hint="@string/portal_full_name_hint"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_placeholder"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/profile_phone"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_field_background"
                android:hint="@string/portal_phone_hint"
                android:inputType="phone"
                android:maxLength="13"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_placeholder"
                android:textSize="14sp" />

            <Button
                android:id="@+id/profile_save"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/button_rounded_pill_green"
                android:stateListAnimator="@null"
                android:text="@string/portal_save_profile"
                android:textAllCaps="false"
                android:textColor="@color/bg_main_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/profile_logout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_field_background"
                android:stateListAnimator="@null"
                android:text="@string/dashboard_logout"
                android:textAllCaps="false"
                android:textColor="@color/text_light_gray"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/portal_nav"
        layout="@layout/include_portal_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
