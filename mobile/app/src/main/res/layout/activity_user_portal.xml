<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    tools:context=".features.dashboard.UserPortalActivity">

    <ScrollView
        android:id="@+id/portal_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/portal_nav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_logo" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/portal_user_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/portal_user_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_muted_gray"
                        android:textSize="12sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/portal_logout"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/input_field_background"
                    android:minWidth="72dp"
                    android:stateListAnimator="@null"
                    android:text="@string/dashboard_logout"
                    android:textAllCaps="false"
                    android:textColor="@color/text_light_gray"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/portal_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_mobile_feature_card"
                android:padding="12dp"
                android:textSize="12sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/section_dashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/portal_title"
                    android:textColor="@color/text_white"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/portal_subtitle"
                    android:textColor="@color/text_muted_gray"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/dashboard_new_report"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_rounded_pill_green"
                        android:stateListAnimator="@null"
                        android:text="@string/portal_create_title"
                        android:textAllCaps="false"
                        android:textColor="@color/bg_main_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/dashboard_view_reports"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_rounded_pill_outline_green"
                        android:stateListAnimator="@null"
                        android:text="@string/portal_all_reports"
                        android:textAllCaps="false"
                        android:textColor="@color/brand_green"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/dashboard_total_reports"
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_mobile_feature_card"
                        android:gravity="center"
                        android:textColor="@color/text_white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/dashboard_total_matches"
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_mobile_feature_card"
                        android:gravity="center"
                        android:textColor="@color/text_white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="@string/portal_recent_reports"
                    android:textColor="@color/text_white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/dashboard_recent_reports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_reports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/portal_all_reports"
                    android:textColor="@color/text_white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/reports_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/button_rounded_pill_outline_green"
                    android:stateListAnimator="@null"
                    android:text="@string/portal_refresh"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_green"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/reports_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_create"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/create_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/portal_create_title"
                    android:textColor="@color/text_white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/create_serial"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/portal_serial_hint"
                    android:inputType="text"
                    android:maxLength="255"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/create_model"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/portal_model_hint"
                    android:inputType="text"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/create_description"
                    android:layout_width="match_parent"
                    android:layout_height="132dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_field_background"
                    android:gravity="top"
                    android:hint="@string/portal_description_hint"
                    android:inputType="textMultiLine"
                    android:padding="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/create_choose_files"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/button_rounded_pill_outline_green"
                    android:stateListAnimator="@null"
                    android:text="@string/portal_choose_files"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_green"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/create_selected_files"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/text_muted_gray"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/create_submit"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/button_rounded_pill_green"
                    android:stateListAnimator="@null"
                    android:text="@string/portal_submit_report"
                    android:textAllCaps="false"
                    android:textColor="@color/bg_main_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/create_cancel_edit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/input_field_background"
                    android:stateListAnimator="@null"
                    android:text="@string/portal_cancel_edit"
                    android:textAllCaps="false"
                    android:textColor="@color/text_light_gray"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_matches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/portal_matched_reports"
                    android:textColor="@color/text_white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/matches_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/portal_profile_title"
                    android:textColor="@color/text_white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/profile_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_mobile_feature_card"
                    android:padding="16dp"
                    android:textColor="@color/text_light_gray"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/profile_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/portal_full_name_hint"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/profile_phone"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/portal_phone_hint"
                    android:inputType="phone"
                    android:maxLength="13"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/profile_save"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/button_rounded_pill_green"
                    android:stateListAnimator="@null"
                    android:text="@string/portal_save_profile"
                    android:textAllCaps="false"
                    android:textColor="@color/bg_main_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/portal_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_nav_glass"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/nav_home"
            style="@style/Widget.AppCompat.TextView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/portal_dashboard"
            android:textColor="@color/brand_green"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_reports"
            style="@style/Widget.AppCompat.TextView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/portal_reports"
            android:textColor="@color/text_muted_gray"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_create"
            style="@style/Widget.AppCompat.TextView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/portal_new_report"
            android:textColor="@color/text_muted_gray"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_matches"
            style="@style/Widget.AppCompat.TextView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/portal_matches"
            android:textColor="@color/text_muted_gray"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_profile"
            style="@style/Widget.AppCompat.TextView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/portal_profile"
            android:textColor="@color/text_muted_gray"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
