<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <ScrollView
        android:id="@+id/verify_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/business_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="34dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Verify Item"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/verify_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_glass_panel_soft"
                android:padding="12dp"
                android:textSize="12sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_glass_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/verify_serial_input"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/input_field_background"
                    android:hint="Enter serial number"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLength="255"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/verify_submit"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/button_rounded_pill_green"
                    android:stateListAnimator="@null"
                    android:text="Verify Item"
                    android:textAllCaps="false"
                    android:textColor="@color/bg_main_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/verify_result_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_detail_hero"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/verify_result_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_status_approved"
                    android:gravity="center"
                    android:minWidth="96dp"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:textColor="@color/brand_green"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/verify_result_serial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="#B3FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/verify_result_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/text_light_gray"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:includeFontPadding="false"
                android:text="Recent Searches"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/verify_recent_searches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/business_nav"
        layout="@layout/include_business_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="74dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
