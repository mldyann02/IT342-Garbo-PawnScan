<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="74dp"
    android:background="@drawable/bg_nav_glass"
    android:baselineAligned="false"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <FrameLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="3dp"
        android:layout_weight="1"
        android:background="@drawable/bg_nav_item_glass"
        android:clickable="true"
        android:contentDescription="Business home"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_home_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nav_home" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/nav_reports"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="3dp"
        android:layout_weight="1"
        android:background="@drawable/bg_nav_item_glass"
        android:clickable="true"
        android:contentDescription="Search history"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_reports_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nav_reports" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/nav_create"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="3dp"
        android:layout_weight="1"
        android:background="@drawable/bg_nav_item_glass"
        android:clickable="true"
        android:contentDescription="Verify item"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_create_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nav_add" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/nav_matches"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="3dp"
        android:layout_weight="1"
        android:background="@drawable/bg_nav_item_glass"
        android:clickable="true"
        android:contentDescription="Stolen matches"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_matches_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nav_matches" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="3dp"
        android:layout_weight="1"
        android:background="@drawable/bg_nav_item_glass"
        android:clickable="true"
        android:contentDescription="Profile"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_profile_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nav_profile" />
    </FrameLayout>
</LinearLayout>
