<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_mobile_feature_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/match_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/match_serial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_muted_gray"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/match_business"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/brand_green"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/match_contact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_light_gray"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/match_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_muted_gray"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/match_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_placeholder"
        android:textSize="12sp" />
</LinearLayout>
