<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main_dark">

    <!-- Navigation Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_main_dark"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <!-- Logo and Brand Name - Left -->
        <LinearLayout
            android:id="@+id/logo_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Shield/Hexagon Icon -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_logo_shield"
                android:tint="@color/brand_green" />

            <!-- Brand Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Sign In - Center Right -->
        <TextView
            android:id="@+id/nav_sign_in"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/nav_get_started"
            android:layout_marginEnd="24dp"
            android:text="@string/nav_sign_in"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Get Started Button - Far Right -->
        <Button
            android:id="@+id/nav_get_started"
            android:layout_width="100dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:text="@string/nav_get_started"
            android:textColor="@color/bg_main_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/button_rounded_pill_green"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_muted" />

    <!-- Scrollable Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_green_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/landing_badge_text"
                    android:src="@drawable/ic_sparkle"
                    android:tint="@color/brand_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_badge_text"
                    android:textColor="@color/brand_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Headline - Stop stolen goods before they sell -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_headline_line1"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="44sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_headline_line2"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="44sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_headline_line3"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="44sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_headline_green"
                    android:textColor="@color/brand_green"
                    android:textStyle="bold"
                    android:textSize="44sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- Subheadline -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/landing_subheadline"
                android:textColor="@color/text_muted_gray"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <!-- CTA Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Primary CTA Button -->
                <Button
                    android:id="@+id/btn_report_stolen"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/landing_cta_primary"
                    android:textColor="@color/bg_main_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_rounded_pill_green"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="12dp" />

                <!-- Secondary CTA Button -->
                <Button
                    android:id="@+id/btn_business_verification"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/landing_cta_secondary"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_rounded_pill_outline_green"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Bottom padding for scroll -->
            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>