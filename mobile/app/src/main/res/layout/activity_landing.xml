<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main_dark">

    <!-- Navigation Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/bg_main_dark"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical">

        <!-- Brand Name - Left -->
        <TextView
            android:id="@+id/logo_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/app_name"
            android:textColor="@color/brand_green"
            android:textSize="20sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:letterSpacing="0.05" />

        <!-- Sign In - Center Right -->
        <TextView
            android:id="@+id/nav_sign_in"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/nav_get_started"
            android:layout_centerVertical="true"
            android:layout_marginEnd="20dp"
            android:text="@string/nav_sign_in"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Get Started Button - Far Right -->
        <Button
            android:id="@+id/nav_get_started"
            android:layout_width="100dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/nav_get_started"
            android:textColor="@color/bg_main_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:gravity="center"
            android:includeFontPadding="false"
            android:background="@drawable/button_rounded_pill_green"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_muted" />

    <!-- Scrollable Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_green_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/landing_badge_text"
                    android:src="@drawable/ic_sparkle"
                    android:tint="@color/brand_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_badge_text"
                    android:textColor="@color/brand_green"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"
                    android:gravity="center"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <!-- Headline - Stop stolen goods before they sell -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="40dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_headline_line1"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="48sp"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp"
                    android:includeFontPadding="false"
                    android:paddingBottom="0dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_headline_line2"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="48sp"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp"
                    android:includeFontPadding="false"
                    android:paddingBottom="0dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="before they"
                    android:textColor="@color/brand_green"
                    android:textStyle="bold"
                    android:textSize="48sp"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp"
                    android:includeFontPadding="false"
                    android:paddingBottom="0dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/landing_headline_green"
                    android:textColor="@color/brand_green"
                    android:textStyle="bold"
                    android:textSize="48sp"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- Subheadline -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/landing_subheadline"
                android:textColor="@color/text_muted_gray"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:lineSpacingExtra="1dp"
                android:includeFontPadding="false" />

            <!-- CTA Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="48dp">

                <!-- Primary CTA Button -->
                <Button
                    android:id="@+id/btn_report_stolen"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/landing_cta_primary"
                    android:textColor="@color/bg_main_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/button_rounded_pill_green"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="16dp"
                    android:stateListAnimator="@null" />

                <!-- Secondary CTA Button -->
                <Button
                    android:id="@+id/btn_business_verification"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/landing_cta_secondary"
                    android:textColor="@color/text_white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/button_rounded_pill_outline_green"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>