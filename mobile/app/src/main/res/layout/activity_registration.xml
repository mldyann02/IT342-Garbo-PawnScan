<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_nav_glass"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@android:string/cancel"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:id="@+id/logo_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:includeFontPadding="false"
            android:text="@string/app_name"
            android:textColor="@color/brand_green"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="28dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/registration_title"
                android:textColor="@color/text_white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:includeFontPadding="false"
                android:lineSpacingExtra="3dp"
                android:text="@string/registration_subtitle"
                android:textColor="@color/text_muted_gray"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_auth_card"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="20dp">

                <View
                    android:layout_width="160dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_auth_accent" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:includeFontPadding="false"
                    android:text="@string/registration_account_type_label"
                    android:textColor="@color/text_light_gray"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_toggle_track"
                    android:baselineAligned="false"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btn_individual"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/toggle_left_active"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:stateListAnimator="@null"
                        android:text="@string/registration_individual"
                        android:textAllCaps="false"
                        android:textColor="@color/bg_main_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_business"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/toggle_right_inactive"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:stateListAnimator="@null"
                        android:text="@string/registration_business"
                        android:textAllCaps="false"
                        android:textColor="@color/text_white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <EditText
                    android:id="@+id/full_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/registration_full_name_hint"
                    android:includeFontPadding="false"
                    android:inputType="text"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp"
                    android:visibility="visible" />

                <EditText
                    android:id="@+id/business_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/registration_business_name_hint"
                    android:includeFontPadding="false"
                    android:inputType="text"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/business_address_input"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/registration_business_address_hint"
                    android:includeFontPadding="false"
                    android:inputType="text"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/permit_number_input"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/registration_permit_number_hint"
                    android:includeFontPadding="false"
                    android:inputType="text"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/email_input"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/registration_email_hint"
                    android:includeFontPadding="false"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/phone_input"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_field_background"
                    android:hint="@string/registration_phone_hint"
                    android:includeFontPadding="false"
                    android:inputType="phone"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_placeholder"
                    android:textSize="14sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/password_input"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/input_field_background"
                        android:hint="@string/registration_password_hint"
                        android:includeFontPadding="false"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:textColor="@color/text_white"
                        android:textColorHint="@color/text_placeholder"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btn_toggle_password"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="5dp"
                        android:adjustViewBounds="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/registration_show_password"
                        android:padding="7dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_eye_open"
                        android:stateListAnimator="@null" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/confirm_password_input"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/input_field_background"
                        android:hint="@string/registration_confirm_password_hint"
                        android:includeFontPadding="false"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:textColor="@color/text_white"
                        android:textColorHint="@color/text_placeholder"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btn_toggle_confirm_password"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="5dp"
                        android:adjustViewBounds="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/registration_show_password"
                        android:padding="7dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_eye_open"
                        android:stateListAnimator="@null" />
                </FrameLayout>

                <TextView
                    android:id="@+id/status_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_mobile_feature_card"
                    android:includeFontPadding="false"
                    android:paddingStart="12dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="10dp"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/registration_terms"
                    android:textColor="@color/text_muted_gray"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btn_create_account"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/button_rounded_pill_green"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:stateListAnimator="@null"
                    android:text="@string/registration_cta_button"
                    android:textAllCaps="false"
                    android:textColor="@color/bg_main_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sign_in_link"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/registration_sign_in_link"
                    android:textColor="@color/brand_green"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
