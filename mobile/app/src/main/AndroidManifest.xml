<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Notification Permission for Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name="com.cit.pawnscan.PawnScanApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@drawable/ic_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.PawnScan"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="pawnscan_alerts" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/status_stolen" />

        <activity
            android:name="com.cit.pawnscan.features.landing.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.PawnScan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.cit.pawnscan.features.landing.MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.PawnScan">
        </activity>
        
        <activity
            android:name="com.cit.pawnscan.features.auth.RegistrationActivity"
            android:exported="false"
            android:label="@string/registration_title"
            android:theme="@style/Theme.PawnScan" />
        
        <activity
            android:name="com.cit.pawnscan.features.auth.LoginActivity"
            android:exported="false"
            android:label="@string/login_title"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.auth.VerifyOtpActivity"
            android:exported="false"
            android:label="@string/otp_title"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.auth.ForgotPasswordActivity"
            android:exported="false"
            android:label="@string/forgot_password_title"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.auth.ResetPasswordActivity"
            android:exported="false"
            android:label="@string/reset_password_title"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.auth.CompleteProfileActivity"
            android:exported="false"
            android:label="@string/complete_profile_title"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.dashboard.TemporaryDashboardActivity"
            android:exported="false"
            android:label="@string/dashboard_welcome_title"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.dashboard.UserDashboardActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.business.BusinessDashboardActivity"
            android:exported="false"
            android:label="Business Portal"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.business.BusinessVerifyActivity"
            android:exported="false"
            android:label="Verify Item"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.business.BusinessHistoryActivity"
            android:exported="false"
            android:label="Search History"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.business.BusinessMatchDetailActivity"
            android:exported="false"
            android:label="Stolen Match"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.business.BusinessProfileActivity"
            android:exported="false"
            android:label="Business Profile"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.dashboard.NotificationsActivity"
            android:exported="false"
            android:label="Notifications"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.reports.ReportsActivity"
            android:exported="false"
            android:label="@string/portal_all_reports"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.reports.ReportFormActivity"
            android:exported="false"
            android:label="@string/portal_create_title"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.reports.ReportDetailActivity"
            android:exported="false"
            android:label="@string/portal_all_reports"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.matches.MatchedReportsActivity"
            android:exported="false"
            android:label="@string/portal_matched_reports"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.matches.MatchDetailActivity"
            android:exported="false"
            android:label="@string/portal_matched_reports"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.shared.ui.EvidencePreviewActivity"
            android:exported="false"
            android:label="@string/evidence_preview_title"
            android:theme="@style/Theme.PawnScan" />

        <activity
            android:name="com.cit.pawnscan.features.profile.ProfileActivity"
            android:exported="false"
            android:label="@string/portal_profile_title"
            android:theme="@style/Theme.PawnScan" />

        <!-- FCM Background / Foreground Handler Service -->
        <service
            android:name="com.cit.pawnscan.shared.notification.PawnScanMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
